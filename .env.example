POSTGRES_USER=promptyard
POSTGRES_PASSWORD=change_me
POSTGRES_DB=promptyard

DATABASE_URL=postgresql://promptyard:change_me@localhost:5432/promptyard

# Keycloak admin bootstrap (dev only)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change_me

# BetterAuth
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me
BETTER_AUTH_URL=http://localhost:3000

# Keycloak OpenID Connect (mock corporate identity provider)
KEYCLOAK_ISSUER=http://localhost:8080/realms/promptyard
KEYCLOAK_CLIENT_ID=promptyard-website
KEYCLOAK_CLIENT_SECRET=promptyard-website-dev-secret
